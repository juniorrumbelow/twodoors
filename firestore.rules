rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Each document ID is a property ID. Users can only manage their own favourites.
      match /favourites/{propertyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

  }
}
